# .env
# Міняти тільки 3 параметри при потребі:
# tool_timeout_sec: якщо часто зависає/timeout, збільшуйте на +5.
# max_iterations: якщо відповідь обривається занадто рано, збільшуйте на +1.
# debug: true коли треба діагностика, false для звичайної роботи.

# OpenAI Configuration
openai_api_key=sk-proj-YOUR_OPENAI_API_KEY

# Agent control
max_iterations=10
tool_timeout_sec=40
agent_first_wait_sec=60
agent_second_wait_sec=30

# Model Settings
model_name=gpt-4o
# Output Configuration
output_dir=output
# Debug Mode
debug=false

# Search / content limits
max_search_results=5
max_url_content_length=5000

# RAG
embedding_model=text-embedding-3-small
reranker_model=BAAI/bge-reranker-base
data_dir=data
index_dir=index
chunks_path=index/chunks.json

chunk_size=800
chunk_overlap=120
semantic_top_k=8
bm25_top_k=8
hybrid_top_k=10
rerank_top_n=4
